{
  "name": "@fakoli/openclaw-speech-to-speech",
  "version": "0.1.0",
  "description": "Realtime speech-to-speech providers for OpenClaw using Anvil Serving or user-owned OpenAI-compatible endpoints",
  "type": "module",
  "license": "MIT",
  "author": "Sekou Doumbouya",
  "homepage": "https://github.com/fakoli/openclaw-speech-to-speech#readme",
  "bugs": {
    "url": "https://github.com/fakoli/openclaw-speech-to-speech/issues"
  },
  "keywords": [
    "openclaw",
    "speech-to-speech",
    "realtime",
    "voice",
    "stt",
    "tts",
    "openai-compatible",
    "anvil"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fakoli/openclaw-speech-to-speech.git"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "ws": "8.21.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0",
    "openclaw": "2026.6.11",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  }
}
