{
  "id": "speech-to-speech",
  "name": "Speech to Speech",
  "description": "Realtime speech-to-speech voice provider over the OpenClaw Gateway relay",
  "activation": {
    "onStartup": false
  },
  "enabledByDefault": false,
  "contracts": {
    "realtimeVoiceProviders": [
      "anvil"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "realtimeUrl": {
        "type": "string",
        "description": "Realtime backend WebSocket URL."
      },
      "baseUrl": {
        "type": "string",
        "description": "Realtime backend HTTP or WebSocket base URL; /v1/realtime is appended when needed."
      },
      "apiKey": {
        "type": [
          "string",
          "object"
        ],
        "description": "Optional bearer token or secret reference for non-loopback realtime endpoints."
      },
      "token": {
        "type": [
          "string",
          "object"
        ],
        "description": "Alias for apiKey."
      },
      "model": {
        "type": "string"
      },
      "voice": {
        "type": "string"
      },
      "speakerVoice": {
        "type": "string"
      },
      "vadThreshold": {
        "type": "number"
      },
      "silenceDurationMs": {
        "type": "number"
      },
      "prefixPaddingMs": {
        "type": "number"
      }
    }
  }
}
