{
  "id": "speech-to-speech",
  "name": "Speech to Speech",
  "description": "Realtime speech-to-speech over Anvil Serving or user-owned OpenAI-compatible STT, LLM, and TTS endpoints",
  "activation": {
    "onStartup": false
  },
  "enabledByDefault": false,
  "contracts": {
    "realtimeVoiceProviders": [
      "anvil-serving",
      "openai-cascade"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "realtimeUrl": {
        "type": "string",
        "description": "Realtime backend WebSocket URL."
      },
      "baseUrl": {
        "type": "string",
        "description": "Realtime backend HTTP or WebSocket base URL; /v1/realtime is appended when needed."
      },
      "apiKey": {
        "type": [
          "string",
          "object"
        ],
        "description": "Optional bearer token or secret reference for non-loopback realtime endpoints."
      },
      "token": {
        "type": [
          "string",
          "object"
        ],
        "description": "Alias for apiKey."
      },
      "model": {
        "type": "string"
      },
      "voice": {
        "type": "string"
      },
      "speakerVoice": {
        "type": "string"
      },
      "vadThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "silenceDurationMs": {
        "type": "integer",
        "minimum": 0
      },
      "prefixPaddingMs": {
        "type": "integer",
        "minimum": 0
      },
      "sttBaseUrl": {
        "type": "string",
        "description": "OpenAI-compatible STT HTTP base URL."
      },
      "sttApiKey": {
        "type": ["string", "object"],
        "description": "Optional bearer token or secret reference for the STT endpoint."
      },
      "sttModel": {
        "type": "string"
      },
      "llmBaseUrl": {
        "type": "string",
        "description": "OpenAI-compatible Chat Completions HTTP base URL."
      },
      "llmApiKey": {
        "type": ["string", "object"],
        "description": "Optional bearer token or secret reference for the LLM endpoint."
      },
      "llmModel": {
        "type": "string"
      },
      "ttsBaseUrl": {
        "type": "string",
        "description": "OpenAI-compatible TTS HTTP base URL."
      },
      "ttsApiKey": {
        "type": ["string", "object"],
        "description": "Optional bearer token or secret reference for the TTS endpoint."
      },
      "ttsModel": {
        "type": "string"
      },
      "ttsSampleRateHz": {
        "type": "integer",
        "minimum": 8000,
        "maximum": 384000,
        "description": "TTS PCM response sample rate; defaults to 24000."
      },
      "requestTimeoutMs": {
        "type": "integer",
        "minimum": 1,
        "maximum": 2147483647,
        "description": "Per-stage upstream request deadline in milliseconds; defaults to 60000."
      }
    }
  }
}
